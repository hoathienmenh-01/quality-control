# Database
POSTGRES_USER=qc_user
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=quality_control
POSTGRES_PORT=5432
DATABASE_URL=postgresql://qc_user:your_password_here@postgres:5432/quality_control
LAZADATA_DATABASE_URL=postgresql://qc_user:your_password_here@postgres:5432/quality_control

# Redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# API
API_PORT=8000
SECRET_KEY=your-secret-key-change-this
API_KEY=your-api-key-change-this
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=development

# Frontend
FRONTEND_PORT=3000

# Camera
CAMERA_ID=0
CAMERA_RESOLUTION_WIDTH=1920
CAMERA_RESOLUTION_HEIGHT=1080

# Telegram Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Thresholds
DEFECT_RATE_THRESHOLD=10.0

# Export
EXPORT_DIR=./exports
