# ============================================================
# QC System — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=qc_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=quality_control
POSTGRES_PORT=5432
DATABASE_URL=postgresql://qc_user:CHANGE_ME_STRONG_PASSWORD@postgres:5432/quality_control

# ── API ───────────────────────────────────────────────────────
# Generate SECRET_KEY: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
API_KEY=
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=production
API_PORT=8000

# ── CORS (comma-separated origins) ───────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Frontend ──────────────────────────────────────────────────
FRONTEND_PORT=3000

# ── Camera ────────────────────────────────────────────────────
CAMERA_ID=0
CAMERA_RESOLUTION_WIDTH=1920
CAMERA_RESOLUTION_HEIGHT=1080

# ── Telegram Alerts ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Thresholds ────────────────────────────────────────────────
DEFECT_RATE_THRESHOLD=10.0
CONSECUTIVE_FAIL_THRESHOLD=5
ALERT_THRESHOLD_RATE=0.1

# ── Export ────────────────────────────────────────────────────
EXPORT_DIR=./exports
